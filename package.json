{
  "name": "teleprompter-pro",
  "version": "2.10.0",
  "description": "Sistema profesional de teleprónter con reconocimiento de voz, control remoto y gestión de guiones multiparticipante.",
  "main": "server.js",
  "bin": "server.js",
  "license": "AGPL-3.0-or-later",
  "author": "Sergio Marlop",
  "homepage": "https://github.com/marlop-sergio/teleprompter",
  "repository": {
    "type": "git",
    "url": "https://github.com/marlop-sergio/teleprompter.git"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:win": "node build-win.js",
    "postinstall": "node download-fonts.js"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "pngjs": "^7.0.0",
    "rcedit": "^3.0.1",
    "resedit": "^3.0.2",
    "to-ico": "^1.1.5"
  },
  "packageManager": "pnpm@9.0.0"
}
